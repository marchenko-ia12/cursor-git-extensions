{
  "name": "git-branch-switcher",
  "displayName": "Git Branch Switcher",
  "description": "JetBrains-style branches popup with multi-repo support, drill-down actions, push/pull, log, compare, rename — for VS Code and Cursor.",
  "version": "0.2.0",
  "publisher": "marchenko-ia12",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["SCM Providers", "Other"],
  "keywords": [
    "git",
    "branches",
    "branch",
    "switcher",
    "checkout",
    "multi-repo",
    "monorepo",
    "jetbrains",
    "popup"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marchenko-ia12/cursor-git-extensions",
    "directory": "packages/branches-popup"
  },
  "bugs": {
    "url": "https://github.com/marchenko-ia12/cursor-git-extensions/issues"
  },
  "homepage": "https://github.com/marchenko-ia12/cursor-git-extensions/tree/main/packages/branches-popup#readme",
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gitBranchSwitcher.open",
        "title": "Show Branches Popup",
        "category": "Git Branch Switcher"
      }
    ],
    "keybindings": [
      {
        "command": "gitBranchSwitcher.open",
        "key": "ctrl+shift+`",
        "mac": "cmd+shift+`"
      }
    ],
    "configuration": {
      "title": "Git Branch Switcher",
      "properties": {
        "branchesPopup.pullStrategy": {
          "type": "string",
          "enum": ["ask", "merge", "rebase", "ffOnly"],
          "enumDescriptions": [
            "If fast-forward is not possible, pop up a Merge / Rebase picker (IntelliJ Smart Update behaviour).",
            "Always merge: git pull --no-rebase.",
            "Always rebase: git pull --rebase (linear history).",
            "Fast-forward only: fail if histories have diverged."
          ],
          "default": "ask",
          "markdownDescription": "How **Pull** and **Update** reconcile divergent branches.\n\n- `ask` *(default)* — try fast-forward, prompt Merge / Rebase if it diverged.\n- `merge` — always `git pull --no-rebase`.\n- `rebase` — always `git pull --rebase`.\n- `ffOnly` — fail loud if fast-forward is not possible."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --allow-missing-repository --skip-license --no-dependencies",
    "vscode:prepublish": "npm run build"
  }
}

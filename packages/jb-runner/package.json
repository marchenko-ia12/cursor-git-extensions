{
  "name": "jb-runner",
  "displayName": "JB Runner",
  "description": "JetBrains-style run toolbar for VS Code and Cursor: pick an npm script, hit ▶, stop with ⏹ — right in the status bar.",
  "version": "0.2.0",
  "publisher": "marchenko-ia12",
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "keywords": [
    "npm",
    "scripts",
    "run",
    "runner",
    "jetbrains",
    "webstorm",
    "toolbar",
    "tasks"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marchenko-ia12/cursor-git-extensions",
    "directory": "packages/jb-runner"
  },
  "bugs": {
    "url": "https://github.com/marchenko-ia12/cursor-git-extensions/issues"
  },
  "homepage": "https://github.com/marchenko-ia12/cursor-git-extensions/tree/main/packages/jb-runner#readme",
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jbRunner.run",
        "title": "Run current configuration",
        "category": "JB Runner",
        "icon": {
          "light": "resources/play.svg",
          "dark": "resources/play.svg"
        }
      },
      {
        "command": "jbRunner.stop",
        "title": "Stop running configuration",
        "category": "JB Runner",
        "icon": {
          "light": "resources/stop.svg",
          "dark": "resources/stop.svg"
        }
      },
      {
        "command": "jbRunner.pickConfig",
        "title": "Pick run configuration",
        "category": "JB Runner"
      },
      {
        "command": "jbRunner.showOutput",
        "title": "Show output of running configuration",
        "category": "JB Runner"
      },
      {
        "command": "jbRunner.addConfig",
        "title": "Add custom configuration",
        "category": "JB Runner"
      },
      {
        "command": "jbRunner.editConfigs",
        "title": "Edit configurations (settings.json)",
        "category": "JB Runner"
      }
    ],
    "configuration": {
      "title": "JB Runner",
      "properties": {
        "jbRunner.configurations": {
          "type": "array",
          "default": [],
          "markdownDescription": "Custom run configurations. Each entry is launched as a shell command in its own terminal — independent from `package.json` scripts.",
          "items": {
            "type": "object",
            "required": ["name", "command"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name shown in the picker and status bar."
              },
              "command": {
                "type": "string",
                "description": "Shell command to run (e.g. 'make run', 'python manage.py runserver')."
              },
              "cwd": {
                "type": "string",
                "description": "Working directory, absolute or relative to the first workspace folder. Defaults to the workspace root."
              },
              "env": {
                "type": "object",
                "description": "Environment variables merged into the terminal on launch.",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "jbRunner.run",
          "group": "navigation@1",
          "when": "!jbRunner.running"
        },
        {
          "command": "jbRunner.stop",
          "group": "navigation@1",
          "when": "jbRunner.running"
        }
      ]
    },
    "keybindings": [
      {
        "command": "jbRunner.run",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "!terminalFocus"
      },
      {
        "command": "jbRunner.stop",
        "key": "ctrl+f2",
        "mac": "cmd+f2"
      },
      {
        "command": "jbRunner.pickConfig",
        "key": "ctrl+alt+shift+r",
        "mac": "cmd+alt+shift+r",
        "when": "!terminalFocus"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --allow-missing-repository --skip-license --no-dependencies",
    "vscode:prepublish": "npm run build"
  }
}
